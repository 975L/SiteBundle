{
    "name": "c975l/site-bundle",
    "type": "symfony-bundle",
    "description": "Symfony bundle that provides a complete foundation for building websites — layout, pages, SEO, admin, sitemap, legal templates, and more.",
    "keywords": ["symfony", "bundle", "website"],
    "homepage": "https://github.com/975L/SiteBundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Laurent Marquet",
            "email": "laurent.marquet@laposte.net",
            "homepage": "https://github.com/LaurentMarquet",
            "role": "Developer"
        },
        {
            "name": "975L Community",
            "homepage": "https://github.com/975L"
        }
    ],
    "require": {
        "php": ">=8.1",
        "c975l/config-bundle": "*",
        "c975l/social-bundle": "*",
        "c975l/ui-bundle": "*",
        "doctrine/orm": "*",
        "dragonmantank/cron-expression": "*",
        "easycorp/easyadmin-bundle": "*",
        "endroid/qr-code": "^6",
        "symfony/form": "*",
        "symfony/framework-bundle": "*",
        "symfony/mailer": "*",
        "symfony/messenger": "*",
        "symfony/process": "*",
        "symfony/scheduler": "*",
        "symfony/string": "*",
        "symfony/ux-twig-component": "*",
        "symfonycasts/reset-password-bundle": "*",
        "twig/cssinliner-extra": "*",
        "vich/uploader-bundle": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "c975L\\SiteBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "c975L\\SiteBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "vendor-dir": ".vendor"
    },
    "scripts": {
        "test": "phpunit"
    },
    "support": {
        "email": "contact@975l.com",
        "source": "https://github.com/975L/SiteBundle",
        "issues": "https://github.com/975L/SiteBundle/issues"
    }
}
