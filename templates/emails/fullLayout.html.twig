{% set site = config('site-name') %}
{% set author = config('site-author') %}
{% set firstOnlineDate = config('site-first-online-date') %}
{% if site_media('logo') is not null %}
    {% set logo = config('site-url') ~ '/' ~ site_media('logo').filename %}
{% endif %}

{# Copyright #}
{% if firstOnlineDate is defined %}
    {% set copyright = '© ' ~ firstOnlineDate|date('Y') ~ ' - ' ~  'now'|date('Y') %}
{% endif %}
{% if copyright is not defined %}
    {% set copyright = '© ' ~  'now'|date('Y') %}
{% endif %}
{% if site is defined %}
    {% set copyright = copyright ~ ': ' ~ site %}
{% endif %}

{% apply inline_css %}
<!DOCTYPE html>
    {# Head #}
    <head>
        {% block head %}
            {% block meta %}
                <meta charset="utf-8" />
                <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
                <meta name="viewport" content="width=device-width initial-scale=1.0 maximum-scale=1.0 user-scalable=no" />
                <meta name="format-detection" content="telephone=no" />
                {# Author #}
                {% if author is defined %}
                    <meta name="author" content="{{ author }}" />
                {% endif %}
                {# Copyright #}
                {% if copyright is defined %}
                    <link rel="copyright" title="{{ copyright }}" />
                {% endif %}
            {% endblock %}
            {# Stylesheets #}
            {% block stylesheets %}
                <style>
                    {# Defaults (incl. :root variables) come first so the theme overrides below can win the cascade #}
                    {{ source('@c975LSiteCss/emails.min.css') }}
                    {{ theme_variables_css() }}
                </style>
            {% endblock %}
        {% endblock %}
    </head>
    {# Body #}
    <body>
        {% block body %}
            {# Header #}
            {% block header %}
                {# No Spam info #}
                {% block noSpam %}
                    {% if config('email-text-no-spam') %}
                        {{ config('email-text-no-spam')|raw }}
                    {% endif %}
                {% endblock %}
                {# Logo #}
                {% block logo %}
                    <h1 class="text-center">
                        {% if logo is defined %}
                            <img src="{{ logo }}" height="50" alt="logo" />
                        {% elseif site is defined %}
                            {{ site }}
                        {% endif %}
                    </h1>
                {% endblock %}
                {# User's header #}
                {% include '@c975LSite/emails/header.html.twig' %}
            {% endblock %}
            {# Container #}
            {% block container %}
                {# Content #}
                {% block content %}
                    {# Hello #}
                    {% block hello %}
                        {% if config('email-text-hello') %}
                            {{ config('email-text-hello')|raw }}
                        {% endif %}
                    {% endblock %}
                    {% block email_content %}
                    {% endblock %}
                {% endblock %}
            {% endblock %}
            {# Footer #}
            {% block footer %}
                <hr />
                {# Thanks confidence & regards #}
                {% if config('email-text-closing') %}
                    {{ config('email-text-closing')|replace({'%site%': site|default('')})|raw }}
                {% endif %}
                {# User's footer #}
                {% include '@c975LSite/emails/footer.html.twig' %}
                {# Email sent by #}
                {% if config('email-text-sent-by') %}
                    {{ config('email-text-sent-by')|replace({'%site%': site|default('')})|raw }}
                {% endif %}
                {# Additional legal mentions (legal form, share capital, registration number...) #}
                {% if config('email-text-legal') %}
                    <p class="text text-muted text-center small">
                        {{ config('email-text-legal')|raw }}
                    </p>
                {% endif %}
                {# Copyright #}
                {% if copyright is defined %}
                    <div class="text-center">
                        <ul class="inline">
                            <li>{{ copyright }}</li>
                        </ul>
                    </div>
                {% endif %}
            {% endblock %}
        {% endblock %}
    </body>
</html>
{% endapply %}