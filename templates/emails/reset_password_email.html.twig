{% extends "@c975LSite/emails/layout.html.twig" %}

{% set title = 'label.reset_password'|trans({}, 'site') %}

{# Content is composed via the "password_reset" EmailTemplate, editable from the admin (see
   c975L\UiBundle\Controller\Management\EmailTemplateCrudController) - seeded by
   DefaultPagesImporter::ensureFormAndEmailTemplateExist(), self-healing here on every request #}
{% block content %}
    {{ email_template_body('password_reset', {
        reset_url: url('app_reset_password', {token: resetToken.token}),
        expires_at: 'text.link_expires_in'|trans({}, 'site') ~ ' ' ~ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle'),
    }) }}
{% endblock %}
