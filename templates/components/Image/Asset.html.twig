{# Kept for retrocompatibility, use <twig:c975LSite:Image:Image> instead #}
<twig:c975LSite:Image:Image
    label="{{ label }}"
    src="{{ src }}"
    class="{{ class }}"
    classLabel="{{ classLabel }}"
    alt="{{ alt }}"
    width="{{ width }}"
    height="{{ height }}"
    above="{{ above }}"
/>