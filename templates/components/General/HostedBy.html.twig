{# <twig:c975LSite:General:HostedBy url="https://..." logo="https://..." [class="your-class"] [classLabel="your-class-label"] ["height"=""] [width=""]/> #}
<twig:c975LSite:Image:Link
    label="{{ 'label.hosted_by'|trans({}, 'site') }}"
    src="{{ logo }}"
    url="{{ url }}"
    target="_blank"
    above="true"
    class="{{ class|default('') }}"
    classLabel="{{ classLabel|default('') }}"
    width="{{ width|default("") }}"
    height="{{ height|default("") }}"
/>