{# <twig:c975LSite:General:Footer [copyright="{{ copyright }}"]> #}
{% set footerBlocks = menu_blocks('footer') %}
{# A menu_link targeting the site's own "Copyright" page (see MenuExtension::isMenuLinkCopyright(),
   "site-menu-link-copyright-auto") already renders the live computed copyright as its label - unless
   a custom "label" (MenuLinkType) overrides it - showing the plain $copyright span too would just
   duplicate it #}
{% set hasCopyrightLink = footerBlocks|filter(
    block => (block.data.label ?? '') is empty and menu_link_is_copyright(block.data.target ?? '')
)|length > 0 %}
<footer>
    <div class="menu-items">
        <twig:c975LUi:Blocks:Blocks blocks="{{ footerBlocks }}" />
        {% if not hasCopyrightLink and copyright is defined and copyright is not empty %}
            <div class="menu-item">
                <span class="menu-label">{{ copyright }}</span>
            </div>
        {% endif %}
    </div>
    {% if config('display-made-by') or config('display-hosted-by') %}
        <div class="made-by">
            {% if config('display-made-by') %}
                <twig:c975LSite:General:MadeBy />
            {% endif %}
            {% if config('display-hosted-by') %}
                <twig:c975LSite:General:HostedBy />
            {% endif %}
        </div>
    {% endif %}
</footer>
{% if config('site-enable-matomo') %}
    <twig:c975LSite:General:Matomo />
{% endif %}
{% if config('site-enable-cookie-consent') %}
    <twig:c975LSite:General:CookieConsent />
{% endif %}
