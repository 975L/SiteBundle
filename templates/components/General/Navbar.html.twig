{# <twig:c975LSite:General:Navbar/> #}
{% set logo = site_media('logo') %}
{% set siteName = config('site-name') %}
{% set siteTagline = config('site-tagline') %}
{% set showSiteName = config('site-navbar-show-name') %}
{# Whitelisted rather than passed through as-is: this value is interpolated straight into an inline
   style="--navbar-position: ...;" attribute below, and CSS custom properties aren't escaped by Twig's
   html_attr context the way quotes/angle brackets are #}
{% set navbarPosition = config('site-navbar-position') in ['relative', 'sticky', 'fixed', 'static', 'absolute'] ? config('site-navbar-position') : null %}

{% if menu_blocks('navbar') is not empty %}
    {# navbarPosition is free text (relative/sticky/fixed/static...) - empty leaves the template's
       own --navbar-position default (_variables.scss) in place; "fixed" additionally needs the
       .menu-fixed class for its edge-to-edge/z-index treatment (see _menu.scss) #}
    <nav class="hidden-print menu{{ navbarPosition == 'fixed' ? ' menu-fixed' : '' }}"{% if navbarPosition %} style="--navbar-position: {{ navbarPosition }};"{% endif %} data-controller="menu">
        <div class="menu-header">
            <div class="menu-brand">
                <div class="menu-brand-top">
                    {% if logo is not null %}
                        <a href="{{ path('page_home') }}" class="menu-logo">
                            <img src="{{ asset('/' ~ logo.filename) }}" alt="{{ siteName|default('Logo') }}" height="40" loading="lazy">
                        </a>
                    {% endif %}

                    {% if showSiteName and siteName is not null %}
                        <p class="menu-site-name">{{ siteName }}</p>
                    {% endif %}
                </div>

                {# site-tagline is authored via a rich-text field in the backoffice, so it comes back wrapped in a <div> #}
                {% if siteTagline is not null %}
                    <div class="menu-site-tagline">{{ siteTagline|raw }}</div>
                {% endif %}
            </div>

            <button class="menu-toggle" data-action="click->menu#toggle" aria-label="{{ 'menu.toggle'|trans({}, 'site') }}" aria-expanded="false">
                <svg class="menu-toggle-icon" viewBox="0 0 448 512" aria-hidden="true" focusable="false">
                    <path d="M0 96C0 78.3 14.3 64 32 64H416c17.7 0 32 14.3 32 32s-14.3 32-32 32H32C14.3 128 0 113.7 0 96zM0 256c0-17.7 14.3-32 32-32H416c17.7 0 32 14.3 32 32s-14.3 32-32 32H32c-17.7 0-32-14.3-32-32zM448 416c0 17.7-14.3 32-32 32H32c-17.7 0-32-14.3-32-32s14.3-32 32-32H416c17.7 0 32 14.3 32 32z"/>
                </svg>
            </button>
        </div>

        <div class="menu-items" data-menu-target="items">
            <twig:c975LUi:Blocks:Blocks blocks="{{ menu_blocks('navbar') }}" />
        </div>
    </nav>
{% else %}
    <nav class="hidden-print">
        {% if logo is not null %}
            <p class="text-center">
                <a href="{{ path('page_home') }}" aria-label="{{ siteName|default('Logo') }}">
                    <img src="{{ asset('/' ~ logo.filename) }}" alt="{{ siteName|default('Logo') }}" class="img" height="70" loading="lazy">
                </a>
            </p>
        {% endif %}
    </nav>
{% endif %}