{% extends '@EasyAdmin/page/content.html.twig' %}

{# Intermediate "pick a group" screen shown by CollectionItemCrudController::index() whenever no "group" is
   selected yet - one row per distinct group, linking into the same index filtered to it (?group=...). #}
{% block main %}
    <h1>{{ ('label.collection_items'|trans({}, 'site')) }}</h1>

    <p>{{ ('label.info_collection_item_groups'|trans({}, 'site')) }}</p>

    <p class="mb-3">
        <a href="{{ newUrl }}" class="btn btn-primary">{{ newLabel }}</a>
    </p>

    {% if counts|length > 0 %}
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>{{ ('label.group'|trans({}, 'site')) }}</th>
                        <th>{{ ('label.collection_items_count'|trans({}, 'site')) }}</th>
                    </tr>
                </thead>
                <tbody>
                {% for group, count in counts %}
                    <tr>
                        <td>
                            <a href="{{ ea_url().setAction('index').set('group', group) }}">{{ group }}</a>
                        </td>
                        <td>{{ count }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <p>{{ ('label.collection_items_none'|trans({}, 'site')) }}</p>
    {% endif %}
{% endblock main %}
