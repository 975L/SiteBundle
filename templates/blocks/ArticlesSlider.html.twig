{# Adapter for the dynamic Block system — gathers the "article" blocks of the chosen page and renders them as a clickable slider #}
{% set page = site_page(pageId) %}
{% if page %}
    {% set slides = [] %}
    {% for articleBlock in page.blocks %}
        {% if articleBlock.kind == 'article' and articleBlock.media|length > 0 %}
            {% set slides = slides|merge([{
                image: articleBlock.media.first,
                title: articleBlock.data.title|default(''),
                text: articleBlock.data.content|default('')|striptags|slice(0, 160),
                url: path('page_display', {page: page.slug}) ~ '#article-' ~ articleBlock.data.slug|default('')
            }]) %}
        {% endif %}
    {% endfor %}
    <twig:c975LUi:Slider:Slider slides="{{ slides }}" id="articles-slider-{{ block.id }}" duration="{{ duration }}"/>
{% endif %}
