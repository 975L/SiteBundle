{% if config('site-name') != null %}
    {% set site = config('site-name') %}
{% endif %}
{% if config('site-author') != null %}
    {% set author = config('site-author') %}
{% endif %}
{% if config('site-first-online-date') != null %}
    {% set firstOnlineDate = config('site-first-online-date') %}
{% endif %}
{% if site_media('logo') is not null %}
    {% set logo = absolute_url(asset('/' ~ site_media('logo').filename)) ~ (site_media('logo').updatedAt ? '?v=' ~ site_media('logo').updatedAt.timestamp : '') %}
{% endif %}
{% if site_media('favicon') is not null %}
    {% set favicon = absolute_url(asset('/' ~ site_media('favicon').filename)) ~ (site_media('favicon').updatedAt ? '?v=' ~ site_media('favicon').updatedAt.timestamp : '') %}
{% endif %}
{% if site_media('apple-touch-icon') is not null %}
    {% set appleTouchIcon = absolute_url(asset('/' ~ site_media('apple-touch-icon').filename)) ~ (site_media('apple-touch-icon').updatedAt ? '?v=' ~ site_media('apple-touch-icon').updatedAt.timestamp : '') %}
{% endif %}

{# Copyright #}
{% if firstOnlineDate is defined %}
    {% if firstOnlineDate|date('Y') == 'now'|date('Y') %}
        {% set copyright = '© ' ~  'now'|date('Y') %}
    {% else %}
        {% set copyright = '© ' ~ firstOnlineDate|date('Y') ~ ' - ' ~  'now'|date('Y') %}
    {% endif %}
{% endif %}
{% if copyright is not defined %}
    {% set copyright = '© ' ~  'now'|date('Y') %}
{% endif %}
{% if site is defined %}
    {% set copyright = copyright ~ ' : ' ~ site %}
{% endif %}

{# ogImage: page-specific override, then the site's default og-image, then the logo #}
{% if ogImage is not defined or ogImage == null %}
    {% if page is defined and page.ogImage is not null %}
        {% set ogImage = absolute_url(asset('/' ~ page.ogImage.filename)) ~ (page.ogImage.updatedAt ? '?v=' ~ page.ogImage.updatedAt.timestamp : '') %}
    {% elseif site_media('og-image') is not null %}
        {% set ogImage = absolute_url(asset('/' ~ site_media('og-image').filename)) ~ (site_media('og-image').updatedAt ? '?v=' ~ site_media('og-image').updatedAt.timestamp : '') %}
    {% elseif logo is defined %}
        {% set ogImage = logo %}
    {% endif %}
{% endif %}

{# pageTitle #}
{% if title is defined and title != '' %}
    {% set pageTitle = title %}
{% endif %}
{% if site is defined %}
    {% if pageTitle is defined %}
        {% set pageTitle = pageTitle ~ ' - ' ~ site %}
    {% else %}
        {% set pageTitle = site %}
    {% endif %}
{% endif %}

{# Display #}
{% if display is not defined %}
    {% set display = 'html' %}
{% endif %}

{# Locale #}
{% if locale is not defined %}
    {% set locale = app.request.locale %}
{% endif %}

<!DOCTYPE html>
{# theme-mode ("light"/"dark"/"auto"): admin-wide choice, applies to every visitor. "auto" (or unset)
   leaves data-theme unset, so @media (prefers-color-scheme: dark) in _theme-dark.scss takes over #}
<html lang="{{ locale }}"{% if config('theme-mode') in ['light', 'dark'] %} data-theme="{{ config('theme-mode') }}"{% endif %}>
{# Head #}
    <head>
        {% block head %}
            {% block meta %}
                <meta charset="utf-8">
                <meta http-equiv="X-UA-Compatible" content="IE=edge">
                <meta name="viewport" content="width=device-width initial-scale=1.0">
                <meta name="format-detection" content="telephone=no">
{# Turbo reads this to nonce the inline <script>/<style> tags it re-executes on page visits/frame
   loads - without it, Turbo recreates them without a nonce and NelmioSecurityBundle's CSP blocks
   them, since a nonce being present at all makes 'unsafe-inline' ignored by the browser #}
                <meta name="csp-nonce" content="{{ csp_nonce('script') }}">
{# Base #}
                <base href="{{ app.request.getSchemeAndHttpHost() ~ app.request.getBaseURL() ~ '/' }}">
{# Display for html #}
                {% if display != 'pdf' %}
                    <meta name="robots" content="index, follow">
{# Site #}
                    {% if site is defined %}
                        <meta property="og:site_name" content="{{ site }}">
                    {% endif %}
{# Author #}
                    {% if author is defined %}
                        <meta name="author" content="{{ author }}">
                    {% endif %}
{# Copyright #}
                    {% if copyright is defined %}
                        <meta name="copyright" content="{{ copyright }}">
                    {% endif %}
{# Description #}
                    {% if summarySocialNetwork is defined and summarySocialNetwork is not empty %}
                        <meta name="description" content="{{ summarySocialNetwork|striptags }}">
                        <meta property="og:description" content="{{ summarySocialNetwork|striptags|slice(0,150) }}">
                    {% endif %}
{# Title #}
                    {% if pageTitle is defined %}
                        <title>{{ pageTitle }}</title>
                        <meta name="title" content="{{ pageTitle }}">
                        <meta property="og:title" content="{{ pageTitle }}">
                    {% endif %}
{# Type #}
                    <meta property="og:type" content="website">
{# Image #}
                    {% if ogImage is defined %}
                        <meta property="og:image" content="{{ ogImage }}">
                    {% endif %}
{# Url #}
                    <meta property="og:url" content="{{ app.request.uri }}">
                    <link rel="canonical" href="{{ app.request.uri }}">
{# Favicon #}
                    {% if favicon is defined%}
                        <link rel="icon" type="image/x-icon" href="{{ favicon }}">
                    {% endif %}
{# Apple-touch-icon #}
                    {% if appleTouchIcon is defined%}
                        <link rel="apple-touch-icon" href="{{ appleTouchIcon }}">
                        <link rel="apple-touch-icon-precomposed" href="{{ appleTouchIcon }}">
                    {% endif %}
{# hreflang #}
                    {% if languagesAlt is defined %}
                        {% for languageAlt, item in languagesAlt %}
                            {% if app.request.uri ends with '/' ~ locale %}
                                {% set sourceLanguage = '/' ~ locale %}
                                {% set targetLanguage = '/' ~ languageAlt %}
                            {% else %}
                                {% set sourceLanguage = '/' ~ locale ~ '/' %}
                                {% set targetLanguage = '/' ~ languageAlt ~ '/' %}
                            {% endif %}
                            <link rel="alternate" hreflang="{{ languageAlt }}" href="{{ app.request.uri|replace({(sourceLanguage): targetLanguage}) }}">
                        {% endfor %}
                    {% else %}
                        <link rel="alternate" hreflang="{{ locale }}" href="{{ app.request.uri }}">
                    {% endif %}
{# End display for html #}
                {% endif %}
            {% endblock %}
{# Stylesheets #}
            {% block stylesheets %}
                {% for stylesheet in bundle_stylesheets() %}
                    <link rel="stylesheet" href="{{ stylesheet }}">
                {% endfor %}
            {% endblock %}
{# Preconnect #}
            {% block preconnect %}
                {% for preconnectUrl in config('site-preconnect') %}
                    <link rel="preconnect" href="{{ preconnectUrl }}">
                {% endfor %}
            {% endblock %}
{# Javascript #}
            {% if display != 'pdf' %}
                {% block javascripts %}
                    {% block importmap %}
                        {{ importmap(['app']|merge(bundle_scripts()), {'nonce': csp_nonce('script')}) }}
                    {% endblock %}
                {% endblock %}
{# End display for html #}
            {% endif %}
        {% endblock %}
    </head>
{# Body #}
    <body id="top" class="{{ config('site-navbar-fixed') ? 'navbar-fixed' : '' }}" data-controller="basic">
{# jQuery #}
        {% block jquery %}
        {% endblock %}
{# Block body #}
        {% block body %}
            {% if display != 'pdf' %}
{# backTop/pullDown bookmarks #}
                <a href="{{ app.request.uri }}#top" class="backTop" aria-label="Top">Top</a>
                <a href="{{ app.request.uri }}#bottom" class="pullDown" aria-label="Bottom"></a>
            {% endif %}
{# Header #}
            {% block header %}
                <header>
{# Navigation #}
                    {% if display != 'pdf' %}
                        {% block navigation %}
                            <twig:c975LSite:General:Navbar />
                        {% endblock %}
                    {% endif %}
                </header>
            {% endblock %}
{# Title #}
            {% block main %}
                <main>
                    {% block title %}
                        {% if title is defined and title != '' %}
                            <h1>
                                {{ title }}
                            </h1>
                        {% endif %}
                    {% endblock %}
{# Flashes #}
                    {% if display != 'pdf' %}
                        {% block flashes %}
                            {% for label, messages in app.flashes %}
                                {% for message in messages %}
                                    <div class="flash alert alert-{{ label }} text-center" role="alert">
                                        {{ message|raw|nl2br }}
                                    </div>
                                {% endfor %}
                            {% endfor %}
                        {% endblock %}
                    {% endif %}
{# Container #}
                    {% block container %}
{# Content #}
                        <div class="container">
                            {% block content %}
                            {% endblock %}
                        </div>
                    {% endblock %}
{# Share #}
                    {% if display != 'pdf' %}
                        {% if config('social-enable-share-buttons') %}
                            {{ share_buttons_default() }}
                        {% endif %}
                    {% endif %}
{# NavigationBottom #}
                    {% if display != 'pdf' %}
                        {% block share %}
                            {% block navigationBottom %}
                            {% endblock %}
                        {% endblock %}
                    {% endif %}
                </main>
            {% endblock %}
{# Footer #}
            {% block footer %}
                <twig:c975LSite:General:Footer copyright="{{ copyright is defined ? copyright : '' }}" />
            {% endblock %}
        {% endblock %}
        <span id="bottom"></span>
    </body>
</html>