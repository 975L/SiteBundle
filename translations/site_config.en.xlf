        <body>
            <trans-unit id="1">
                <source>description.site_name</source>
                <target>Name of the web site: i.e. Example.com</target>
            </trans-unit>
            <trans-unit id="2">
                <source>description.site_tagline</source>
                <target>Tagline of the website</target>
            </trans-unit>
            <trans-unit id="3">
                <source>description.site_navbar_show_name</source>
                <target>Display the site name (and tagline) next to the logo in the navbar</target>
            </trans-unit>
            <trans-unit id="4">
                <source>description.site_navbar_fixed</source>
                <target>Keep the navbar fixed at the top of the viewport while scrolling</target>
            </trans-unit>
            <trans-unit id="5">
                <source>description.site_author</source>
                <target>The author that will be set in the meta data</target>
            </trans-unit>
            <trans-unit id="6">
                <source>description.site_first_online_date</source>
                <target>Date when the site went online (YYYY-MM-DD)</target>
            </trans-unit>
            <trans-unit id="7">
                <source>description.site_url</source>
                <target>URL of the website i.e. https://example.com</target>
            </trans-unit>
            <trans-unit id="8">
                <source>description.url_terms_of_use</source>
                <target>URL of the terms of use page i.e. https://example.com/pages/terms-of-use</target>
            </trans-unit>
            <trans-unit id="9">
                <source>description.site_hosted_by_url</source>
                <target>URL of the hosting company i.e. https://example.com</target>
            </trans-unit>
            <trans-unit id="10">
                <source>description.site_hosted_by_logo</source>
                <target>Path or URL of the hosting company logo</target>
            </trans-unit>
            <trans-unit id="11">
                <source>description.site_made_by_url</source>
                <target>URL of the developer/agency i.e. https://example.com</target>
            </trans-unit>
            <trans-unit id="12">
                <source>description.site_made_by_logo</source>
                <target>Path or URL of the developer/agency logo</target>
            </trans-unit>
            <trans-unit id="13">
                <source>description.url_cookies_policy</source>
                <target>URL of the cookies policy page i.e. https://example.com/pages/cookies</target>
            </trans-unit>
            <trans-unit id="14">
                <source>description.site_matomo_url</source>
                <target>URL of the Matomo instance i.e. https://matomo.example.com</target>
            </trans-unit>
            <trans-unit id="15">
                <source>description.site_matomo_id</source>
                <target>Matomo site ID (integer)</target>
            </trans-unit>
            <trans-unit id="16">
                <source>description.site_preconnect</source>
                <target>External origins to preconnect to (JSON array), i.e. ["https://example.com"]. Useful when credits logos or Matomo are hosted on a third-party domain</target>
            </trans-unit>
            <trans-unit id="17">
                <source>description.site_backup_db_host</source>
                <target>MySQL host for backups</target>
            </trans-unit>
            <trans-unit id="18">
                <source>description.site_backup_db_user</source>
                <target>MySQL user for backups</target>
            </trans-unit>
            <trans-unit id="19">
                <source>description.site_backup_db_password</source>
                <target>MySQL password for backups</target>
            </trans-unit>
            <trans-unit id="20">
                <source>description.site_backup_database</source>
                <target>Name of the MySQL database to back up</target>
            </trans-unit>
            <trans-unit id="21">
                <source>description.site_backup_mailto</source>
                <target>Email address for backup reports and error notifications</target>
            </trans-unit>
            <trans-unit id="22">
                <source>description.site_contact_email</source>
                <target>Public contact email address displayed on legal pages</target>
            </trans-unit>
