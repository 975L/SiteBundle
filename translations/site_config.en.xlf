            </trans-unit>
            <trans-unit id="33">
                <source>description.user_roles_available</source>
                <target>Extra roles selectable for users in the backoffice (besides the default ROLE_USER), as a JSON array i.e. ["ROLE_ADMIN","ROLE_EDITOR"]</target>
            </trans-unit>
            <trans-unit id="34">
