            </trans-unit>
            <trans-unit id="81">
                <source>description.email_text_no_spam</source>
                <target>"No spam" notice displayed at the top of the email (HTML allowed, not translated - same value shown regardless of the email's language). Leave empty to display nothing</target>
            </trans-unit>
            <trans-unit id="82">
                <source>description.email_text_hello</source>
                <target>Greeting displayed at the top of the email (HTML allowed, not translated). Leave empty to display nothing</target>
            </trans-unit>
            <trans-unit id="83">
                <source>description.email_text_closing</source>
                <target>Thank-you and signature text displayed at the bottom of the email. Use %site% to insert the site name (HTML allowed, not translated). Leave empty to display nothing</target>
            </trans-unit>
            <trans-unit id="84">
                <source>description.email_text_sent_by</source>
                <target>"This email was sent by..." notice displayed at the bottom of the email. Use %site% to insert the site name (HTML allowed, not translated). Leave empty to display nothing</target>
            </trans-unit>
            <trans-unit id="89">
                <source>description.email_text_legal</source>
                <target>Free text block displayed at the bottom of the email for extra legal mentions (legal form, share capital, company registration number...) (HTML allowed, not translated). Empty by default - displays nothing until filled in</target>
            </trans-unit>
